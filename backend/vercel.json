{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "toolbox.wsgi.application"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "toolbox.settings"
  },
  "functions": {
    "toolbox/wsgi.py": {
      "runtime": "python3.9"
    }
  }
}
